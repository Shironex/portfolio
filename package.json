{
  "name": "portfolio",
  "version": "2.8.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:email": "email dev -p 3001 --dir ./src/lib/mail/templates",
    "build": "next build --turbopack",
    "analyze": "ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier 'src/**/*.{js,ts,jsx,tsx}' --write",
    "format:check": "prettier 'src/**/*.{js,ts,jsx,tsx}' --check",
    "release": "standard-version",
    "debug-release": "node scripts/debug-release.js",
    "generate:icons": "node scripts/generate-icons.mjs",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=10.9.0"
  },
  "packageManager": "pnpm@10.9.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "minimatch@9": ">=9.0.7",
      "rollup@4": ">=4.59.0",
      "serialize-javascript": ">=7.0.3",
      "handlebars": ">=4.7.9",
      "flatted": ">=3.4.2",
      "picomatch@4": ">=4.0.4",
      "micromatch>picomatch": ">=4.0.4",
      "brace-expansion@>=5": ">=5.0.5"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "5.10.1",
    "jiti": "^2.6.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-safe-action": "^8.5.2",
    "nextjs-toploader": "^3.9.17",
    "posthog-js": "^1.371.2",
    "posthog-node": "^5.30.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-intersection-observer": "^10.0.3",
    "react-turnstile": "^1.1.5",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@next/eslint-plugin-next": "^16.2.4",
    "@react-email/preview-server": "5.2.10",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@tailwindcss/postcss": "^4.2.4",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-n": "^17.24.0",
    "husky": "^9.1.7",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-email": "^5.2.10",
    "semantic-release": "^25.0.3",
    "sharp": "^0.34.5",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "license": "MIT",
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
