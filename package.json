{
  "name": "portfolio",
  "version": "2.8.6",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:email": "email dev -p 3001 --dir ./src/lib/mail/templates",
    "build": "next build --turbopack",
    "analyze": "ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier 'src/**/*.{js,ts,jsx,tsx}' --write",
    "format:check": "prettier 'src/**/*.{js,ts,jsx,tsx}' --check",
    "release": "standard-version",
    "debug-release": "node scripts/debug-release.js",
    "generate:icons": "node scripts/generate-icons.mjs",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=10.9.0"
  },
  "packageManager": "pnpm@10.9.0",
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "5.10.1",
    "jiti": "^2.7.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "next-safe-action": "^8.5.3",
    "posthog-js": "^1.383.0",
    "posthog-node": "^5.36.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "react-intersection-observer": "^10.0.3",
    "react-turnstile": "^1.1.5",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "^16.2.7",
    "@next/eslint-plugin-next": "^16.2.7",
    "@react-email/preview-server": "5.2.10",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@tailwindcss/postcss": "^4.3.0",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.1",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-n": "^18.1.0",
    "husky": "^9.1.7",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-email": "^5.2.10",
    "semantic-release": "^25.0.3",
    "sharp": "^0.34.5",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "license": "MIT",
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
